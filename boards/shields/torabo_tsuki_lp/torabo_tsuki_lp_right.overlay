#include "torabo_tsuki_lp.dtsi"
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>

/* 1. ポインティングリスナーの設定 */
&pointing_listener {
    input-processors = 
        /* XY反転設定 */
        <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)>,
        /* オートマウス(レイヤー5)設定 */
        <&zip_temp_layer 5 2000>,
        /* 【修正点】レイヤー6にいる時だけスクロールに変換する設定 */
        <&zip_scroll_transform 6>;
};

/* 2. オートマウス除外キー設定 */
&zip_temp_layer {
    excluded-positions = <
        19 // U
        21 // O
        33 // J (MB1)
        34 // K (MB3)
        35 // L (MB2)
    >;
};

/* 3. スクロールの速度設定 */
&zip_scroll_scaler {
    scroll-speed = <100>;
};

/* 4. 既存のレイアウト変換設定（維持） */
&size_s_transform { col-offset = <7>; };
&size_m_transform { col-offset = <7>; };
&size_l_transform { col-offset = <7>; };
